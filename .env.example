# ─────────────────────────────────────────────────────────────
# Copy to .env.local and fill in.  NEVER commit the real .env.local.
# ─────────────────────────────────────────────────────────────

# ── Supabase (Postgres + Auth) ──
# Create a free project at https://supabase.com → Project Settings → Database.
# Use the "Connection pooling" string (port 6543) for DATABASE_URL,
# and the "Direct connection" string (port 5432) for DIRECT_URL.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."
# Server-only (never expose to client). Used by the caching/settlement jobs.
SUPABASE_SERVICE_ROLE_KEY="ey..."

# ── API-Football ──
# https://dashboard.api-football.com — World Cup is league=1, season=2026.
# NOTE: current-season paid leagues usually require a PAID plan (~$19/mo).
# Run `npm run verify-api` to confirm your key/plan can reach 2026 data.
APISPORTS_KEY="your_api_football_key_here"

# ── Anthropic (Head-to-Head AI challenges) ──
# https://console.anthropic.com/settings/keys — free tier works for dev.
# Used server-side only; never exposed to the browser.
ANTHROPIC_API_KEY="sk-ant-..."

# ── Cron (ROADMAP 3.1) ──
# Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}` to /api/cron/* routes.
# Set this in the Vercel project env (Production) to a long random string. If
# unset, the cron routes accept any request (fine for local dev, NOT production).
CRON_SECRET="a_long_random_string"

# ── Local Docker fallback (only if you run `docker compose up`) ──
# Then set DATABASE_URL/DIRECT_URL both to:
# postgresql://wcfpl:wcfpl@localhost:5432/wcfpl
