// World Cup 2026 Fantasy — data model (build-plan section 9).
// This file IS the "agree the schema in hour one" artifact. Everyone builds
// against these types; nobody is blocked on the live feed because the seed
// script (npm run seed) stubs fake data into every table.
//
// After editing: `npx prisma migrate dev --name <change>` then `npx prisma generate`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (Prisma 7+):
  //   url       = DATABASE_URL  (pooled, Supabase pgbouncer port 6543)
  //   directUrl = DIRECT_URL    (direct, Supabase port 5432, for migrations)
}

// ───────────────────────── Position / enums ─────────────────────────

enum Position {
  GK
  DEF
  MID
  FWD
}

enum FixtureStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

// Knockout-aware round labels; drives transfer windows + gameweek buckets.
enum RoundType {
  GROUP
  R32
  R16
  QF
  SF
  FINAL
  THIRD_PLACE
}

enum BetStatus {
  OPEN
  WON
  LOST
  VOID
}

enum MarketType {
  // Match-level (priced from /odds, fallback /predictions)
  MATCH_RESULT // 1X2
  OVER_UNDER
  BTTS
  CORRECT_SCORE
  // Player-level (our own markets, fixed point values)
  PLAYER_SCORER
  PLAYER_ASSIST
  PLAYER_CARD
}

// ───────────────────────── Core entities ─────────────────────────

// User — maps 1:1 to a Supabase Auth user (id == auth.users.id UUID).
model User {
  id             String   @id @db.Uuid
  email          String   @unique
  name           String
  teamName       String?
  bettingBalance     Int      @default(5000000) // virtual £ bank — deducted on bet/purchase, credited on win/void
  squadBudgetBonus   Int      @default(0)       // tenths of a million converted from betting bank after group stage
  squadBudgetMerged  Boolean  @default(false)   // true once the post-group leftover-squad-budget → bank merge has run
  supportedNation    String?   // the WC nation the user explicitly picked to represent
  onboardedAt        DateTime? // set when the first-login Welcome guide is dismissed (null = not onboarded yet)
  createdAt          DateTime @default(now())

  squads          Squad[]
  bets            Bet[]
  leagueMembers   LeagueMember[]
  ownedLeagues    League[]       @relation("LeagueOwner")
  perks           UserPerk[]
  h2hCreated      H2HChallenge[] @relation("H2HCreator")
  h2hReceived     H2HChallenge[] @relation("H2HOpponent")
  h2hWon          H2HChallenge[] @relation("H2HWinner")
  gameweekPicks   GameweekPick[]
  playerFavourites PlayerFavourite[]
  parlays         Parlay[]
}

model League {
  id        String   @id @default(cuid())
  name      String
  joinCode  String   @unique
  ownerId   String   @db.Uuid
  owner     User     @relation("LeagueOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())

  members LeagueMember[]
}

model LeagueMember {
  id       String   @id @default(cuid())
  leagueId String
  userId   String   @db.Uuid
  joinedAt DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

// Team — the 48 nations. `country` drives the max-3-per-country squad rule.
model Team {
  id         String  @id @default(cuid())
  apiTeamId  Int     @unique // API-Football team id
  name       String
  country    String
  group      String? // group-stage group label "Group A"…"Group L" (from /standings)
  logoUrl    String?
  eliminated Boolean @default(false)

  players         Player[]
  homeGames       Fixture[]       @relation("HomeTeam")
  awayGames       Fixture[]       @relation("AwayTeam")
  matchEvents     MatchEvent[]    @relation("EventTeam")
  matchStatistics MatchStatistic[] @relation("StatTeam")
  matchLineups    MatchLineup[]   @relation("LineupTeam")
}

// Player — pricing is OUR call (the API gives no projected points).
// Bio + season-stats fields are synced from /players?team=X&season (for the
// player profile/widget UI). All nullable — populated by syncPlayerProfiles,
// 0/empty before that runs.
model Player {
  id          String   @id @default(cuid())
  apiPlayerId Int      @unique
  name        String
  position    Position
  price       Int // tenths of a million? keep integer; e.g. 130 = 13.0M. See seed.
  photoUrl    String?

  // ── bio (from /players profile) ──
  age         Int?
  nationality String?
  heightCm    Int? // parsed from "188 cm"
  weightKg    Int? // parsed from "81 kg"
  injured     Boolean @default(false)

  // ── season stats (from /players?season — accumulates as the tournament plays) ──
  seasonAppearances Int?
  seasonMinutes     Int?
  seasonGoals       Int?
  seasonAssists     Int?
  seasonRating      Float? // average 0–10

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  matchStats   PlayerMatchStat[]
  squadPlayers SquadPlayer[]
  favourites   PlayerFavourite[]

  @@index([teamId])
  @@index([position])
}

// Gameweek — date-bucket (calendar range), NOT a global matchday deadline.
// Group rounds 2 & 3 overlap across groups, so deadlines are calendar ranges.
model Gameweek {
  id        String    @id @default(cuid())
  label     String // e.g. "Group MD1", "Round of 32"
  roundType RoundType
  startsAt  DateTime // window open
  deadline  DateTime // squad/bet lock time
  endsAt    DateTime // window close (last kickoff in bucket)
  isKnockout Boolean  @default(false) // true => opens a transfer window

  fixtures Fixture[]
  squads   Squad[]
  bets     Bet[]
  picks    GameweekPick[]

  @@index([startsAt])
}

model Fixture {
  id          String        @id @default(cuid())
  apiFixtureId Int          @unique
  kickoff     DateTime
  status      FixtureStatus @default(SCHEDULED)
  venue       String?
  homeScore   Int?
  awayScore   Int?

  gameweekId String
  gameweek   Gameweek @relation(fields: [gameweekId], references: [id])

  homeTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId String
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  playerStats     PlayerMatchStat[]
  bets            Bet[]
  odds            FixtureOdds[]
  h2hChallenges   H2HChallenge[]
  parlayLegs      ParlayLeg[]
  matchEvents     MatchEvent[]
  matchStatistics MatchStatistic[]
  matchLineups    MatchLineup[]

  @@index([kickoff])
  @@index([gameweekId])
}

// FixtureOdds — real match-level odds pulled from API-Football /odds, one row
// per (fixture, selection). selection matches betting.ts keys: "HOME"/"DRAW"/
// "AWAY"/"OVER_2.5"/"UNDER_2.5"/"BTTS_YES"/"BTTS_NO". Stored in OUR DB (never
// called per user request). Odds have a 7-day window upstream, so the sync only
// finds them for fixtures within ~a week of kickoff (build-plan §5 gotcha #3).
model FixtureOdds {
  id         String   @id @default(cuid())
  fixtureId  String
  selection  String // e.g. "HOME", "OVER_2.5", "BTTS_YES"
  multiplier Float // decimal odds, e.g. 2.10
  updatedAt  DateTime @updatedAt

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@unique([fixtureId, selection])
  @@index([fixtureId])
}

// PlayerMatchStat — the raw feed (/fixtures/players) that settles BOTH
// fantasy points and player-prop bets. Clean sheets are DERIVED from
// minutes + goalsConceded, not stored as a flag.
model PlayerMatchStat {
  id        String @id @default(cuid())
  playerId  String
  fixtureId String

  minutes        Int     @default(0)
  goals          Int     @default(0)
  assists        Int     @default(0)
  yellowCards    Int     @default(0)
  redCards       Int     @default(0)
  saves          Int     @default(0)
  penaltiesSaved Int     @default(0)
  penaltiesMissed Int    @default(0)
  goalsConceded  Int     @default(0)
  ownGoals       Int     @default(0)
  rating         Float? // API 0–10 rating (bonus-point substitute)

  // Computed FPL points for this player in this fixture (filled by settlement job).
  fantasyPoints Int?

  player  Player  @relation(fields: [playerId], references: [id])
  fixture Fixture @relation(fields: [fixtureId], references: [id])

  @@unique([playerId, fixtureId])
  @@index([fixtureId])
}

// Squad — a user's 15-player team valid from a given gameweek window.
// A new Squad row is created when a knockout transfer window opens.
model Squad {
  id            String @id @default(cuid())
  userId        String @db.Uuid
  gameweekId    String // valid-from window
  captainId     String? // Player.id scoring x2
  transfersUsed Int    @default(0) // transfers made this window (resets with each new Squad row)

  user     User          @relation(fields: [userId], references: [id])
  gameweek Gameweek      @relation(fields: [gameweekId], references: [id])
  players  SquadPlayer[]

  @@unique([userId, gameweekId])
}

model SquadPlayer {
  id       String  @id @default(cuid())
  squadId  String
  playerId String
  isStarting Boolean @default(true) // false => bench (4 benched)

  squad  Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([squadId, playerId])
}

// GameweekPick — the captain + vice a user picks FOR a specific gameweek (FPL:
// captaincy changes every week, even while the squad is locked). Settlement
// reads this per gameweek: captain scores ×2, or the vice does if the captain
// played 0 minutes. Editable until Gameweek.deadline (first kickoff of the GW).
model GameweekPick {
  id         String  @id @default(cuid())
  userId     String  @db.Uuid
  gameweekId String
  captainId  String // Player.id — scores ×2
  viceId     String // Player.id — scores ×2 if the captain doesn't play
  captain2Id String? // Player.id — SECOND captain (also ×2), only with the Extra Captain perk

  user     User     @relation(fields: [userId], references: [id])
  gameweek Gameweek @relation(fields: [gameweekId], references: [id])

  @@unique([userId, gameweekId])
  @@index([userId])
}

// Bet — points-only prediction. payout = stake * multiplier if WON.
model Bet {
  id         String     @id @default(cuid())
  userId     String     @db.Uuid
  gameweekId String
  fixtureId  String? // null for tournament-wide markets
  marketType MarketType
  selection  String // e.g. "HOME", "OVER_2.5", "playerId:scorer"
  stake      Int
  multiplier Float
  status     BetStatus  @default(OPEN)
  payout     Int?
  createdAt  DateTime   @default(now())

  user     User     @relation(fields: [userId], references: [id])
  gameweek Gameweek @relation(fields: [gameweekId], references: [id])
  fixture  Fixture? @relation(fields: [fixtureId], references: [id])

  @@index([userId])
  @@index([gameweekId])
}

// Parlay (accumulator): ONE bet across multiple legs that ALL must win. The
// combined multiplier is the product of the legs' odds; payout = stake × combo.
// Settles as each leg's fixture resolves: LOST the moment any leg loses; WON only
// once every leg has won. (Singles are placed as separate Bet rows, not here.)
model Parlay {
  id         String     @id @default(cuid())
  userId     String     @db.Uuid
  stake      Int
  multiplier Float // product of leg multipliers at placement
  status     BetStatus  @default(OPEN)
  payout     Int? // set on settle (stake × multiplier if WON, else 0)
  createdAt  DateTime   @default(now())

  user User        @relation(fields: [userId], references: [id])
  legs ParlayLeg[]

  @@index([userId])
}

model ParlayLeg {
  id         String     @id @default(cuid())
  parlayId   String
  fixtureId  String
  marketType MarketType
  selection  String // same encoding as Bet.selection (e.g. "HOME", "scorer:<id>")
  pick       String // human label shown in My Bets (e.g. "Messi", "Over 2.5")
  multiplier Float
  status     BetStatus  @default(OPEN) // per-leg resolution

  parlay  Parlay  @relation(fields: [parlayId], references: [id], onDelete: Cascade)
  fixture Fixture @relation(fields: [fixtureId], references: [id])

  @@index([parlayId])
  @@index([fixtureId])
}

// ───────────────────────── Head-to-Head ─────────────────────────

enum H2HStatus {
  PENDING   // waiting for opponent to accept or reject
  ACCEPTED  // both stakes locked; active rivalry
  REJECTED  // opponent rejected; creator stake refunded
  SETTLED   // winner declared; pot paid out
  CANCELLED // creator cancelled while still PENDING; stake refunded
}

// A peer-to-peer side-bet mirroring an existing market selection.
// Creator picks an open bet, nominates a league friend and a stake.
// Friend must match the same stake. Winner takes the full pot (2× stake).
// Settlement is automatic when the linked fixture finishes.
model H2HChallenge {
  id         String    @id @default(cuid())
  creatorId  String    @db.Uuid
  opponentId String    @db.Uuid

  // Market details (copied from the source bet at creation time)
  fixtureId  String    // required — drives auto-settlement
  selection  String    // "HOME" / "AWAY" / "OVER_2.5" / "scorer:id" etc.
  multiplier Float     // house odds at creation (display only)
  pickLabel  String    // human label: "Mexico", "Over 2.5", "Mbappé"

  stake      Int       // each side puts this in; pot = 2 × stake

  status     H2HStatus @default(PENDING)
  winnerId   String?   @db.Uuid
  settledAt  DateTime?
  createdAt  DateTime  @default(now())

  creator  User    @relation("H2HCreator",  fields: [creatorId],  references: [id])
  opponent User    @relation("H2HOpponent", fields: [opponentId], references: [id])
  winner   User?   @relation("H2HWinner",   fields: [winnerId],   references: [id])
  fixture  Fixture @relation(fields: [fixtureId], references: [id])

  @@index([creatorId])
  @@index([opponentId])
  @@index([status])
  @@index([fixtureId])
}

// PlayerFavourite — a player a user has hearted for later reference.
model PlayerFavourite {
  userId    String   @db.Uuid
  playerId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([userId, playerId])
  @@index([userId])
}

// ───────────────────────── Match stats (synced after FINISHED) ─────────────────────────

// In-match events: goals, assists, cards, substitutions.
// playerApiId / assistApiId reference the API-Football player id (no DB FK —
// not every event player is in our Player table).
model MatchEvent {
  id           String  @id @default(cuid())
  fixtureId    String
  teamId       String
  playerApiId  Int? // API-Football player id
  playerName   String
  assistApiId  Int?
  assistName   String?
  minute       Int
  extraMinute  Int?
  type         String  // "Goal" | "Card" | "subst" | "Var"
  detail       String  // "Normal Goal" | "Yellow Card" | "Red Card" | "Substitution 1" etc.
  comments     String?

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  team    Team    @relation("EventTeam", fields: [teamId], references: [id])

  @@index([fixtureId])
  @@index([teamId])
}

// Team-level statistics per fixture (possession %, shots, corners, etc.)
// value stored as-is from the API (e.g. "45%", "12", null → "").
model MatchStatistic {
  id        String @id @default(cuid())
  fixtureId String
  teamId    String
  key       String // "Ball Possession" | "Total Shots" | "Corner Kicks" etc.
  value     String // raw API value

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  team    Team    @relation("StatTeam", fields: [teamId], references: [id])

  @@unique([fixtureId, teamId, key])
  @@index([fixtureId])
}

// Starting XI + bench per team per fixture.
// formation stored once per team (same value on all rows for that team).
model MatchLineup {
  id            String  @id @default(cuid())
  fixtureId     String
  teamId        String
  formation     String? // e.g. "4-3-3" (same for all rows of a team)
  playerApiId   Int
  playerName    String
  playerNumber  Int?
  pos           String? // "G" | "D" | "M" | "F"
  grid          String? // "1:1" | "2:3" — formation grid position (null for bench)
  isSubstitute  Boolean @default(false)

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  team    Team    @relation("LineupTeam", fields: [teamId], references: [id])

  @@unique([fixtureId, teamId, playerApiId])
  @@index([fixtureId])
  @@index([teamId])
}

// StoreItem — catalogue entry (seeded, not user-created).
model StoreItem {
  id          String @id // stable slug, e.g. "perk_country_slot"
  name        String
  description String
  cost        Int    // virtual £ price, same units as User.bettingBalance
  effectKey   String // "country_slot" | "extra_captain" | "extra_transfer" | "bench_boost"

  perks UserPerk[]
}

// UserPerk — a perk a user has purchased.
// gameweekId = null  → permanent (country_slot stays active until used)
// gameweekId = "gw1" → activated for that gameweek
// usedAt = non-null  → perk has been consumed (won't apply any more)
model UserPerk {
  id          String    @id @default(cuid())
  userId      String    @db.Uuid
  storeItemId String
  gameweekId  String?   // which GW this perk is activated for (null = permanent/unactivated)
  usedAt      DateTime? // set when the perk effect is consumed

  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  storeItem StoreItem @relation(fields: [storeItemId], references: [id])

  @@index([userId])
}
